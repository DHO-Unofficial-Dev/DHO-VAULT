{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DHO Vault",
  "version": "0.1.0",
  "identifier": "dev.dho-unofficial.dho-vault",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DHO Vault",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
