{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DHO Vault Curator",
  "version": "0.1.0",
  "identifier": "dev.dho-unofficial.dho-vault.curator",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DHO Vault Curator",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["../../viewer/src-tauri/icons/icon.ico"]
  }
}
